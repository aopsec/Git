#!/usr/bin/env bash
# [FIX-ADV7IA-TOOLS-07] Add repo-local safeguards and env overrides to the RAG MCP wrapper.
set -euo pipefail
shopt -s inherit_errexit

cleanup() {
  :
}

main() {
  local py=""
  local server=""

  py="${ADV7IA_RAG_PYTHON:-${HOME}/.local/rag-local/.venv/bin/python}"
  server="${ADV7IA_RAG_MCP_SERVER:-${HOME}/.local/mcp-servers/rag-aider-test/server.py}"

  if [[ ! -x "${py}" ]]; then
    printf '[ERROR] Python venv not found: %s\n' "${py}" >&2
    exit 127
  fi

  if [[ ! -f "${server}" ]]; then
    printf '[ERROR] RAG MCP server not found: %s\n' "${server}" >&2
    exit 2
  fi

  exec "${py}" "${server}" "$@"
}

trap cleanup EXIT INT
main "$@"
