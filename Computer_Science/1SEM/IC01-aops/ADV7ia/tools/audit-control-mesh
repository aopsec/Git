#!/usr/bin/env bash
# [FIX-ADV7IA-CM-05] Audit the control-mesh templates and optionally the live runtime.
set -euo pipefail
shopt -s inherit_errexit

PASS=0
FAIL=0

cleanup() {
  :
}

ok() {
  local label="$1"
  printf '  [ok]   %s\n' "${label}"
  PASS=$((PASS + 1))
}

nok() {
  local label="$1"
  printf '  [FAIL] %s\n' "${label}" >&2
  FAIL=$((FAIL + 1))
}

assert_file() {
  local path="$1"
  if [[ -f "${path}" ]]; then
    ok "file: ${path}"
  else
    nok "missing file: ${path}"
  fi
}

assert_contains() {
  local pattern="$1"
  local path="$2"
  local label="$3"
  if rg -q --fixed-strings "${pattern}" "${path}"; then
    ok "${label}"
  else
    nok "${label}"
  fi
}

assert_not_contains() {
  local pattern="$1"
  local path="$2"
  local label="$3"
  if rg -q --fixed-strings "${pattern}" "${path}"; then
    nok "${label}"
  else
    ok "${label}"
  fi
}

service_active() {
  local service_name="$1"
  systemctl is-active --quiet "${service_name}" || systemctl --user is-active --quiet "${service_name}"
}

detect_caddy_service() {
  if systemctl is-active --quiet caddy.service; then
    printf '%s\n' "caddy.service"
    return 0
  fi
  if systemctl --user is-active --quiet adv7ia-caddy-lan-proxy.service; then
    printf '%s\n' "adv7ia-caddy-lan-proxy.service"
    return 0
  fi
  return 1
}

live_caddy_probe() {
  local hostname="adv7ia-control.home.arpa"
  local server_ca="${HOME}/.local/share/adv7ia/caddy/server-ca/server-ca.crt"
  local client_cert="${HOME}/.local/share/adv7ia/caddy/clients/adv7ia-lan-client.crt"
  local client_key="${HOME}/.local/share/adv7ia/caddy/clients/adv7ia-lan-client.key"

  if [[ ! -f "${server_ca}" || ! -f "${client_cert}" || ! -f "${client_key}" ]]; then
    echo "[SKIP] Caddy client bundle not available; skipping mTLS probe"
    return 2
  fi

  curl \
    --fail \
    --silent \
    --show-error \
    --max-time 5 \
    --cacert "${server_ca}" \
    --cert "${client_cert}" \
    --key "${client_key}" \
    --resolve "${hostname}:8443:127.0.0.1" \
    "https://${hostname}:8443/health" >/dev/null
}

check_live_runtime() {
  if ! command -v docker >/dev/null 2>&1; then
    echo "[SKIP] docker not available; skipping live runtime audit"
    return 0
  fi
  if ! docker ps --format '{{.Names}}' | grep -qx 'openhands-app'; then
    echo "[SKIP] openhands-app container not running; skipping live runtime audit"
    return 0
  fi

  local binding=""
  binding="$(docker inspect openhands-app --format '{{json .HostConfig.PortBindings}}')"
  if printf '%s' "${binding}" | rg -q '"HostIp":"0.0.0.0"|"HostIp":""'; then
    nok "live runtime publishes OpenHands beyond localhost"
  else
    ok "live runtime keeps OpenHands local-only"
  fi

  local extra_hosts=""
  extra_hosts="$(docker inspect openhands-app --format '{{json .HostConfig.ExtraHosts}}')"
  if printf '%s' "${extra_hosts}" | rg -q 'host\.docker\.internal:host-gateway'; then
    ok "live runtime keeps the host bridge alias for sandboxes"
  else
    nok "live runtime is missing host.docker.internal bridge alias"
  fi

  if service_active openhands-docker-proxy.service; then
    ok "OpenHands bridge proxy service is active"
  else
    nok "OpenHands bridge proxy service is inactive"
  fi

  local caddy_service=""
  if caddy_service="$(detect_caddy_service)"; then
    ok "Caddy LAN proxy service is active (${caddy_service})"
  else
    nok "Caddy LAN proxy service is inactive"
  fi

  if ss -tlnp | rg -q ':8443\b'; then
    ok "Caddy listens on :8443"
  else
    nok "Caddy is not listening on :8443"
  fi

  local caddy_probe_status=0
  if live_caddy_probe; then
    ok "Caddy mTLS health probe succeeds on adv7ia-control.home.arpa:8443"
  else
    caddy_probe_status=$?
    if [[ ${caddy_probe_status} -eq 2 ]]; then
      nok "Caddy mTLS probe bundle is unavailable"
    else
      nok "Caddy mTLS health probe failed on adv7ia-control.home.arpa:8443"
    fi
  fi
}

control_python() {
  if [[ -x "${ROOT}/.venv/bin/python" ]]; then
    printf '%s\n' "${ROOT}/.venv/bin/python"
    return 0
  fi
  printf '%s\n' "python3"
}

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
readonly ROOT
OPENHANDS_COMPOSE="${ROOT}/deploy/openhands/compose.yaml"
readonly OPENHANDS_COMPOSE
CADDYFILE="${ROOT}/deploy/caddy/Caddyfile"
readonly CADDYFILE
LIVE_MODE=0

trap cleanup EXIT INT

if [[ "${1:-}" == "--live" ]]; then
  LIVE_MODE=1
fi

assert_file "${OPENHANDS_COMPOSE}"
assert_file "${CADDYFILE}"
assert_file "${ROOT}/state/policy/control-mesh.json"
assert_file "${ROOT}/state/policy/openhands-reconcile.json"

assert_contains "127.0.0.1:3000:3000" "${OPENHANDS_COMPOSE}" "OpenHands binds only to localhost"
assert_contains "host.docker.internal:host-gateway" "${OPENHANDS_COMPOSE}" "OpenHands keeps the bridge host alias"
assert_contains "USE_HOST_NETWORK: \"false\"" "${OPENHANDS_COMPOSE}" "OpenHands disables host networking"
assert_contains "no-new-privileges:true" "${OPENHANDS_COMPOSE}" "OpenHands keeps no-new-privileges"
assert_contains '${HOME}/.openhands:/.openhands' "${OPENHANDS_COMPOSE}" "OpenHands persists FILE_STORE_PATH"
assert_not_contains "privileged: true" "${OPENHANDS_COMPOSE}" "OpenHands stays non-privileged"
assert_not_contains "network_mode: host" "${OPENHANDS_COMPOSE}" "OpenHands avoids host network mode"

assert_contains "adv7ia-control.home.arpa:8443" "${CADDYFILE}" "Caddy advertises the home.arpa LAN hostname"
assert_contains "bind 0.0.0.0" "${CADDYFILE}" "Caddy binds on the host LAN interfaces"
assert_contains "reverse_proxy 127.0.0.1:3000" "${CADDYFILE}" "Caddy proxies to localhost OpenHands"
assert_contains "client_auth" "${CADDYFILE}" "Caddy requires client authentication"
assert_contains "respond \"forbidden\" 403" "${CADDYFILE}" "Caddy rejects non-allowed traffic"
assert_contains "172.16.0.0/12" "${CADDYFILE}" "Caddy allows private bridge and LAN ranges"

if "$(control_python)" -c 'import pydantic' >/dev/null 2>&1; then
  bash "${ROOT}/tools/control-mesh" brief >/dev/null
  bash "${ROOT}/tools/control-mesh" reconcile --plan >/dev/null
  ok "controller brief renders"
else
  echo "[SKIP] control-mesh dependencies unavailable; skipping controller render probe"
fi

if (( LIVE_MODE == 1 )); then
  check_live_runtime
fi

printf 'pass=%d fail=%d\n' "${PASS}" "${FAIL}"
(( FAIL == 0 ))
