#!/usr/bin/env bash
# [FIX-ADV7IA-TOOLS-08] Bootstrap the default ADV7ia repo RAG collection only when needed.
set -euo pipefail
shopt -s inherit_errexit

cleanup() {
  :
}

usage() {
  cat <<'EOF'
Usage: bootstrap-adv7ia-rag [--rebuild]

Create the default ADV7ia repo RAG collection when it is missing.
Use --rebuild to force a full reindex of the default collection.
EOF
}

script_dir() {
  local dir=""
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  printf '%s\n' "${dir}"
}

collection_status() {
  local qdrant_url="$1"
  local collection="$2"
  curl -s -o /dev/null -w '%{http_code}' --max-time 5 \
    "${qdrant_url}/collections/${collection}" || true
}

main() {
  local tools_dir=""
  local collection=""
  local qdrant_url=""
  local rebuild="0"
  local status_code=""

  tools_dir="$(script_dir)"
  collection="${ADV7IA_RAG_COLLECTION:-adv7ia_repo_rag}"
  qdrant_url="${ADV7IA_QDRANT_URL:-http://127.0.0.1:6333}"

  while (($# > 0)); do
    case "$1" in
      --rebuild)
        rebuild="1"
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        printf '[ERROR] Unknown argument: %s\n' "$1" >&2
        usage >&2
        return 2
        ;;
    esac
    shift
  done

  if [[ "${rebuild}" == "0" ]]; then
    status_code="$(collection_status "${qdrant_url}" "${collection}")"
    case "${status_code}" in
      200)
        printf 'RAG_BOOTSTRAP_OK\n'
        printf 'collection: %s\n' "${collection}"
        printf 'status: already present\n'
        return 0
        ;;
      404)
        ;;
      *)
        printf '[ERROR] Unable to inspect collection %s via %s (HTTP %s)\n' \
          "${collection}" "${qdrant_url}" "${status_code:-unknown}" >&2
        return 1
        ;;
    esac
  fi

  printf '[INFO] Building default ADV7ia RAG collection: %s\n' "${collection}"
  ADV7IA_RAG_COLLECTION="${collection}" bash "${tools_dir}/index-aider-test-rag"
}

trap cleanup EXIT INT
main "$@"
