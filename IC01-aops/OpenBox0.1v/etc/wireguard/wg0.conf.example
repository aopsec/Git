# /etc/wireguard/wg0.conf.example
# OpenBox v0.1 — exemplo. Renomear para wg0.conf e preencher chaves reais.
# Permissoes: chmod 600 /etc/wireguard/wg0.conf

[Interface]
# Chave privada do CLIENTE (gerar: wg genkey | tee privatekey | wg pubkey > publickey)
PrivateKey = REPLACE_WITH_CLIENT_PRIVATE_KEY
Address    = 10.66.66.2/32
DNS        = 127.0.0.1                  # Pi-hole local
MTU        = 1420                        # 1500 - 80 (overhead WG IPv4)
FwMark     = 0xca6c                      # 51820 em hex — usado pelo kill switch
Table      = off                         # rotas gerenciadas manualmente (necessario com fwmark routing)

# Aplica regras de policy routing antes do tunel subir
PreUp  = ip rule add not fwmark 51820 table 51820
PreUp  = ip route add default dev wg0 table 51820

# Aplica MSS clamp para evitar fragmentacao TCP
PostUp = nft add rule inet openbox forward tcp flags syn tcp option maxseg size set rt mtu 2>/dev/null || true

# Limpeza no PreDown
PreDown = ip rule del not fwmark 51820 table 51820 2>/dev/null || true
PreDown = ip route flush table 51820 2>/dev/null || true

[Peer]
# Chave publica do SERVIDOR
PublicKey    = REPLACE_WITH_SERVER_PUBLIC_KEY

# Pre-shared key opcional (resistencia pos-quantica basica)
# Gerar: wg genpsk
PresharedKey = REPLACE_WITH_PSK_OR_REMOVE_LINE

Endpoint     = vpn.exemplo.com:51820
AllowedIPs   = 0.0.0.0/0                # full tunnel (sem IPv6)
PersistentKeepalive = 25
