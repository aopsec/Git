#!/usr/bin/env bash
# [FIX-ADV7IA-TOOLS-04] Query the imported ADV7ia RAG collection by default.
set -euo pipefail
shopt -s inherit_errexit

cleanup() {
  :
}

main() {
  local query_text=""
  local py=""
  local collection=""
  local lm_base_url=""
  local lm_api_key=""
  local embed_model=""
  local qdrant_url=""

  query_text="${*:-local agent validation status}"
  py="${ADV7IA_RAG_PYTHON:-${HOME}/.local/rag-local/.venv/bin/python}"
  collection="${ADV7IA_RAG_COLLECTION:-adv7ia_repo_rag}"
  lm_base_url="${ADV7IA_LM_BASE_URL:-http://127.0.0.1:1234/v1}"
  lm_api_key="${ADV7IA_LM_API_KEY:-local-llm}"
  embed_model="${ADV7IA_EMBED_MODEL:-text-embedding-nomic-embed-text-v1.5}"
  qdrant_url="${ADV7IA_QDRANT_URL:-http://127.0.0.1:6333}"

  if [[ ! -x "${py}" ]]; then
    printf '[ERROR] Python venv not found: %s\n' "${py}" >&2
    exit 127
  fi

  QUERY_TEXT="${query_text}" \
  COLLECTION="${collection}" \
  LM_BASE_URL="${lm_base_url}" \
  LM_API_KEY="${lm_api_key}" \
  EMBED_MODEL="${embed_model}" \
  QDRANT_URL="${qdrant_url}" \
  exec "${py}" - <<'PY'
from __future__ import annotations

import os

from openai import OpenAI
from qdrant_client import QdrantClient

COLLECTION = os.environ["COLLECTION"]
LM_BASE_URL = os.environ["LM_BASE_URL"]
LM_API_KEY = os.environ["LM_API_KEY"]
EMBED_MODEL = os.environ["EMBED_MODEL"]
QDRANT_URL = os.environ["QDRANT_URL"]
query = os.environ["QUERY_TEXT"]

openai_client = OpenAI(base_url=LM_BASE_URL, api_key=LM_API_KEY)
qdrant = QdrantClient(url=QDRANT_URL)

embedding = openai_client.embeddings.create(
    model=EMBED_MODEL,
    input=[query],
).data[0].embedding

result = qdrant.query_points(
    collection_name=COLLECTION,
    query=embedding,
    limit=5,
)

print("RAG_QUERY_OK")
print("query:", query)

for i, point in enumerate(result.points, start=1):
    payload = point.payload
    snippet = payload["text"].replace("\n", " ")[:220]
    print(f"\n[{i}] score={point.score:.6f}")
    print("path:", payload["path"])
    print("chunk:", payload["chunk_index"])
    print("text:", snippet)
PY
}

trap cleanup EXIT INT
main "$@"
