#!/usr/bin/env bash
# [FIX-ADV7IA-TOOLS-05] Point the filesystem MCP wrapper at the imported ADV7ia project.
set -euo pipefail
shopt -s inherit_errexit

cleanup() {
  :
}

main() {
  local root=""
  local target=""
  local bin=""
  local script_dir=""

  root="${ADV7IA_FILESYSTEM_MCP_HOME:-${HOME}/.local/mcp-servers/filesystem}"
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  target="${ADV7IA_FILESYSTEM_TARGET:-$(cd "${script_dir}/.." && pwd)}"
  bin="${root}/node_modules/.bin/mcp-server-filesystem"

  if [[ ! -x "${bin}" ]]; then
    printf '[ERROR] Filesystem MCP binary not found: %s\n' "${bin}" >&2
    printf 'Available bins:\n' >&2
    ls -la "${root}/node_modules/.bin" >&2 || true
    exit 127
  fi

  exec "${bin}" "${target}"
}

trap cleanup EXIT INT
main "$@"
