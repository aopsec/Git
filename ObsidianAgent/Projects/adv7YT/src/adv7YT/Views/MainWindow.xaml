<ui:FluentWindow
    x:Class="adv7YT.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:adv7YT.ViewModels"
    xmlns:models="clr-namespace:adv7YT.Models"
    xmlns:helpers="clr-namespace:adv7YT.Helpers"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
    Title="adv7YT"
    Width="660" Height="520"
    MinWidth="560" MinHeight="440"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <helpers:EnumToBoolConverter x:Key="EnumToBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </ui:FluentWindow.Resources>

    <!-- Custom title bar -->
    <ui:FluentWindow.TitleBar>
        <ui:TitleBar Title="adv7YT">
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" Margin="0,0,8,0">
                    <ui:ToggleSwitch
                        IsChecked="{Binding IsDarkTheme}"
                        Command="{Binding ToggleThemeCommand}"
                        OffContent="Light"
                        OnContent="Dark"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>
    </ui:FluentWindow.TitleBar>

    <Grid Margin="20,8,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- URL input -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Quality selector -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Format dropdowns -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Output folder -->
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>  <!-- Progress bar -->
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>  <!-- Status text -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>  <!-- Action buttons -->
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>     <!-- Log expander -->
        </Grid.RowDefinitions>

        <!-- URL Input Row -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        PlaceholderText="https://youtube.com/watch?v=..."
                        Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                        ClearButtonEnabled="True"
                        IsEnabled="{Binding IsRunning, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
            <ui:Button Grid.Column="2"
                       Content="Paste"
                       Command="{Binding PasteUrlCommand}"/>
        </Grid>

        <!-- Quality Selector -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="Quality:" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <RadioButton Content="Native"
                         GroupName="Quality"
                         IsChecked="{Binding SelectedQuality,
                             Converter={StaticResource EnumToBool},
                             ConverterParameter=Native}"/>
            <RadioButton Content="FHD 1080p" Margin="16,0,0,0"
                         GroupName="Quality"
                         IsChecked="{Binding SelectedQuality,
                             Converter={StaticResource EnumToBool},
                             ConverterParameter=Fhd}"/>
            <RadioButton Content="Fast" Margin="16,0,0,0"
                         GroupName="Quality"
                         IsChecked="{Binding SelectedQuality,
                             Converter={StaticResource EnumToBool},
                             ConverterParameter=Fast}"/>
        </StackPanel>

        <!-- Format Dropdowns -->
        <StackPanel Grid.Row="4" Orientation="Horizontal">
            <TextBlock Text="Format:" VerticalAlignment="Center" Margin="0,0,12,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            <ComboBox Width="155"
                      ItemsSource="{Binding VideoFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      DisplayMemberPath="Label"
                      PlaceholderText="Video"/>
            <ComboBox Width="155" Margin="8,0,0,0"
                      ItemsSource="{Binding AudioFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      DisplayMemberPath="Label"
                      PlaceholderText="Audio"/>
            <ComboBox Width="155" Margin="8,0,0,0"
                      ItemsSource="{Binding ProjectFormats}"
                      SelectedItem="{Binding SelectedFormat}"
                      DisplayMemberPath="Label"
                      PlaceholderText="Project"/>
        </StackPanel>

        <!-- Output Folder -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0"
                        Text="{Binding OutputFolder}"
                        PlaceholderText="Output folder…"
                        IsReadOnly="True"/>
            <ui:Button Grid.Column="2"
                       Content="Browse"
                       Command="{Binding BrowseOutputFolderCommand}"/>
        </Grid>

        <!-- Progress Bar -->
        <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0"
                         Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         Height="10"/>
            <TextBlock Grid.Column="2"
                       Text="{Binding ProgressValue, StringFormat={}{0:F0}%}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- Status Text -->
        <TextBlock Grid.Row="10"
                   Text="{Binding StatusText}"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   FontSize="11"/>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Download"
                       Appearance="Primary"
                       Command="{Binding DownloadCommand}"
                       Width="120"/>
            <ui:Button Content="Convert"
                       Margin="8,0,0,0"
                       Command="{Binding ConvertCommand}"
                       Width="120"/>
        </StackPanel>

        <!-- Collapsible Log -->
        <Expander Grid.Row="14"
                  Header="Log"
                  IsExpanded="{Binding IsLogExpanded}"
                  VerticalAlignment="Stretch">
            <ListBox ItemsSource="{Binding LogLines}"
                     FontFamily="Consolas"
                     FontSize="11"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"/>
        </Expander>
    </Grid>
</ui:FluentWindow>
