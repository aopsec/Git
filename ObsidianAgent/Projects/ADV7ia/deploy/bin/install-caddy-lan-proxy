#!/usr/bin/env bash
# [FIX-ADV7IA-CADDY-03] Install the ADV7ia LAN Caddy proxy in user scope when root-scoped package management is unavailable.
set -euo pipefail
shopt -s inherit_errexit

TMP_DIR=""
DRY_RUN=0

cleanup() {
  if [[ -n "${TMP_DIR}" && -d "${TMP_DIR}" ]]; then
    rm -rf "${TMP_DIR}"
  fi
}

usage() {
  cat <<'EOF'
Usage: install-caddy-lan-proxy [--dry-run]

Download the official Caddy binary, generate the ADV7ia server/client PKI,
and enable the user-scoped adv7ia-caddy-lan-proxy.service unit.
EOF
}

log_info() {
  printf '[INFO] %s\n' "$1"
}

log_error() {
  printf '[ERROR] %s\n' "$1" >&2
}

run_cmd() {
  if [[ "${DRY_RUN}" == "1" ]]; then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

write_content() {
  local path="$1"
  shift

  if [[ "${DRY_RUN}" == "1" ]]; then
    printf '+ write %s\n' "${path}"
    return 0
  fi

  printf '%s\n' "$@" > "${path}"
}

script_dir() {
  local dir=""
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  printf '%s\n' "${dir}"
}

project_root() {
  local dir="$1"
  printf '%s\n' "$(cd "${dir}/../.." && pwd)"
}

download_url() {
  local version="$1"
  printf 'https://github.com/caddyserver/caddy/releases/download/v%s/caddy_%s_linux_amd64.tar.gz\n' "${version}" "${version}"
}

ensure_caddy_binary() {
  local version="$1"
  local install_dir="$2"
  local archive_path="${TMP_DIR}/caddy_${version}_linux_amd64.tar.gz"

  if [[ -x "${install_dir}/caddy" ]]; then
    local current_version=""
    current_version="$("${install_dir}/caddy" version 2>/dev/null || true)"
    if [[ "${current_version}" == "${version}"* || "${current_version}" == "v${version}"* ]]; then
      return 0
    fi
  fi

  log_info "Downloading Caddy ${version}"
  run_cmd curl -fL "$(download_url "${version}")" -o "${archive_path}"
  run_cmd tar -xzf "${archive_path}" -C "${TMP_DIR}"
  run_cmd install -m 0755 "${TMP_DIR}/caddy" "${install_dir}/caddy"
}

ensure_ca() {
  local key_path="$1"
  local cert_path="$2"
  local common_name="$3"

  if [[ -f "${key_path}" && -f "${cert_path}" ]]; then
    return 0
  fi

  log_info "Generating CA ${common_name}"
  run_cmd openssl genrsa -out "${key_path}" 2048
  run_cmd chmod 600 "${key_path}"
  run_cmd openssl req -x509 -new -nodes -key "${key_path}" -sha256 -days 3650 -subj "/CN=${common_name}" -out "${cert_path}"
}

ensure_server_cert() {
  local hostname="$1"
  local server_ca_key="$2"
  local server_ca_cert="$3"
  local server_key="$4"
  local server_cert="$5"
  local csr_path="${TMP_DIR}/server.csr"
  local ext_path="${TMP_DIR}/server.ext"

  if [[ -f "${server_key}" && -f "${server_cert}" ]]; then
    return 0
  fi

  log_info "Generating server certificate for ${hostname}"
  run_cmd openssl genrsa -out "${server_key}" 2048
  run_cmd chmod 600 "${server_key}"
  run_cmd openssl req -new -key "${server_key}" -subj "/CN=${hostname}" -out "${csr_path}"
  write_content "${ext_path}" \
    "basicConstraints=CA:FALSE" \
    "keyUsage=digitalSignature,keyEncipherment" \
    "extendedKeyUsage=serverAuth" \
    "subjectAltName=DNS:${hostname},DNS:localhost,IP:127.0.0.1"
  run_cmd openssl x509 -req -in "${csr_path}" -CA "${server_ca_cert}" -CAkey "${server_ca_key}" -CAcreateserial -out "${server_cert}" -days 825 -sha256 -extfile "${ext_path}"
}

ensure_client_cert() {
  local client_name="$1"
  local client_ca_key="$2"
  local client_ca_cert="$3"
  local client_key="$4"
  local client_cert="$5"
  local client_bundle="$6"
  local password_path="$7"
  local csr_path="${TMP_DIR}/client.csr"
  local ext_path="${TMP_DIR}/client.ext"

  if [[ ! -f "${password_path}" ]]; then
    log_info "Generating client bundle password"
    if [[ "${DRY_RUN}" == "1" ]]; then
      printf '+ openssl rand -hex 16 > %q\n' "${password_path}"
    else
      openssl rand -hex 16 > "${password_path}"
    fi
    run_cmd chmod 600 "${password_path}"
  fi

  if [[ ! -f "${client_key}" || ! -f "${client_cert}" ]]; then
    log_info "Generating client certificate ${client_name}"
    run_cmd openssl genrsa -out "${client_key}" 2048
    run_cmd chmod 600 "${client_key}"
    run_cmd openssl req -new -key "${client_key}" -subj "/CN=${client_name}" -out "${csr_path}"
    write_content "${ext_path}" \
      "basicConstraints=CA:FALSE" \
      "keyUsage=digitalSignature,keyEncipherment" \
      "extendedKeyUsage=clientAuth" \
      "subjectAltName=DNS:${client_name}"
    run_cmd openssl x509 -req -in "${csr_path}" -CA "${client_ca_cert}" -CAkey "${client_ca_key}" -CAcreateserial -out "${client_cert}" -days 825 -sha256 -extfile "${ext_path}"
  fi

  log_info "Refreshing PKCS#12 client bundle"
  run_cmd openssl pkcs12 -export -out "${client_bundle}" -inkey "${client_key}" -in "${client_cert}" -certfile "${client_ca_cert}" -password "file:${password_path}"
}

write_env_file() {
  local env_path="$1"
  local config_path="$2"
  local server_cert="$3"
  local server_key="$4"
  local client_ca_cert="$5"

  log_info "Writing user-scoped Caddy environment file"
  write_content "${env_path}" \
    "ADV7IA_CADDY_CONFIG=${config_path}" \
    "ADV7IA_SERVER_CERT=${server_cert}" \
    "ADV7IA_SERVER_KEY=${server_key}" \
    "ADV7IA_CLIENT_CA=${client_ca_cert}"
}

install_user_unit() {
  local project_root="$1"
  local unit_path="${HOME}/.config/systemd/user/adv7ia-caddy-lan-proxy.service"

  log_info "Installing adv7ia-caddy-lan-proxy.service"
  run_cmd install -D -m 0644 "${project_root}/deploy/systemd-user/adv7ia-caddy-lan-proxy.service" "${unit_path}"
}

wait_for_proxy() {
  local hostname="$1"
  local server_ca="$2"
  local client_cert="$3"
  local client_key="$4"
  local -i remaining=30

  while ((remaining > 0)); do
    if curl --fail --silent --show-error --max-time 5 --cacert "${server_ca}" --cert "${client_cert}" --key "${client_key}" --resolve "${hostname}:8443:127.0.0.1" "https://${hostname}:8443/health" >/dev/null; then
      return 0
    fi
    sleep 1
    ((remaining -= 1))
  done

  return 1
}

main() {
  local script_root=""
  local project_root_path=""
  local caddy_version="${ADV7IA_CADDY_VERSION:-2.11.2}"
  local hostname="${ADV7IA_CADDY_HOSTNAME:-adv7ia-control.home.arpa}"
  local client_name="${ADV7IA_CADDY_CLIENT_NAME:-adv7ia-lan-client}"
  local bin_dir="${HOME}/.local/bin"
  local config_dir="${HOME}/.config/adv7ia"
  local state_dir="${HOME}/.local/share/adv7ia/caddy"
  local server_ca_dir="${state_dir}/server-ca"
  local client_ca_dir="${state_dir}/client-ca"
  local server_dir="${state_dir}/server"
  local client_dir="${state_dir}/clients"
  local server_ca_key="${server_ca_dir}/server-ca.key"
  local server_ca_cert="${server_ca_dir}/server-ca.crt"
  local client_ca_key="${client_ca_dir}/client-ca.key"
  local client_ca_cert="${client_ca_dir}/client-ca.crt"
  local server_key="${server_dir}/server.key"
  local server_cert="${server_dir}/server.crt"
  local client_key="${client_dir}/${client_name}.key"
  local client_cert="${client_dir}/${client_name}.crt"
  local client_bundle="${client_dir}/${client_name}.p12"
  local password_path="${client_dir}/${client_name}.password"
  local env_path="${config_dir}/caddy-lan-proxy.env"
  local host_lan_ip=""

  while (($# > 0)); do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        log_error "Unknown argument: $1"
        usage >&2
        return 2
        ;;
    esac
    shift
  done

  script_root="$(script_dir)"
  project_root_path="$(project_root "${script_root}")"
  TMP_DIR="$(mktemp -d)"
  host_lan_ip="$(ip -o -4 addr show scope global | awk '!/127\\.0\\.0\\.1/ {print $4}' | cut -d/ -f1 | head -n1 || true)"

  run_cmd mkdir -p "${bin_dir}" "${config_dir}" "${server_ca_dir}" "${client_ca_dir}" "${server_dir}" "${client_dir}"

  ensure_caddy_binary "${caddy_version}" "${bin_dir}"
  ensure_ca "${server_ca_key}" "${server_ca_cert}" "ADV7ia Server CA"
  ensure_ca "${client_ca_key}" "${client_ca_cert}" "ADV7ia Client CA"
  ensure_server_cert "${hostname}" "${server_ca_key}" "${server_ca_cert}" "${server_key}" "${server_cert}"
  ensure_client_cert "${client_name}" "${client_ca_key}" "${client_ca_cert}" "${client_key}" "${client_cert}" "${client_bundle}" "${password_path}"
  write_env_file "${env_path}" "${project_root_path}/deploy/caddy/Caddyfile" "${server_cert}" "${server_key}" "${client_ca_cert}"
  install_user_unit "${project_root_path}"

  log_info "Reloading and starting user-scoped Caddy service"
  run_cmd systemctl --user daemon-reload
  run_cmd systemctl --user enable --now adv7ia-caddy-lan-proxy.service

  if [[ "${DRY_RUN}" == "0" ]]; then
    if ! wait_for_proxy "${hostname}" "${server_ca_cert}" "${client_cert}" "${client_key}"; then
      log_error "Caddy did not pass the local mTLS health probe"
      return 1
    fi
  fi

  log_info "Caddy LAN proxy is ready at https://${hostname}:8443"
  log_info "Server CA: ${server_ca_cert}"
  log_info "Client certificate: ${client_cert}"
  log_info "Client key: ${client_key}"
  log_info "Client PKCS#12 bundle: ${client_bundle}"
  log_info "Client bundle password file: ${password_path}"
  if [[ -n "${host_lan_ip}" ]]; then
    log_info "Map ${hostname} to ${host_lan_ip} in LAN DNS or client hosts files."
  fi
}

trap cleanup EXIT INT
main "$@"
