# AgentMesh gateway secrets — copy to `.env` (gitignored) and set strong values.
# `.env` is the LiteLLM container's env_file AND compose's variable source.

# Admin key for LiteLLM: mints/revokes per-user virtual keys (Phase 4). NEVER ship to clients.
LITELLM_MASTER_KEY=sk-mesh-master-CHANGEME-use-a-long-random-string

# Postgres password (LiteLLM state: virtual keys, budgets, audit).
POSTGRES_PASSWORD=CHANGEME-strong-random

# ── Phase 2: cloud providers (uncomment + fill to enable cloud routing/fallback) ──
# Egress to these hosts is allowlisted via the Squid proxy; everything else denied.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# OPENROUTER_API_KEY=
