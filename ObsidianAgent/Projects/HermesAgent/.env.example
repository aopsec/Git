# HermesAgent environment — copy to `.env` (gitignored) and adjust.
# No LLM API key is needed: inference is 100% local via Ollama on the GPU.

# Map the in-container non-root `hermes` user (UID 10000) to your host user so the
# RW vault mount is writable without root-owned files. Use your host id/-u and id/-g.
HERMES_UID=1000
HERMES_GID=1000

# Localhost-only dashboard port (published to 127.0.0.1 only). Confirm the actual
# default with `hermes dashboard --help` on the local box and align both sides.
HERMES_DASHBOARD_PORT=9119

# Optional non-LLM tool keys (web search, etc.) — leave unset unless a tool needs one.
# Any host these keys talk to must ALSO be added to squid/squid-allowlist.conf,
# otherwise the egress proxy will block the request.
# SEARXNG_URL=
# TAVILY_API_KEY=
