# /etc/tor/torrc — OpenBox v0.1
# Hardened para uso como cliente SOCKS5 outbound (NAO relay, NAO exit).

# ===== SOCKS5 outbound com isolation maxima =====
SOCKSPort 127.0.0.1:9050 IsolateClientAddr IsolateSOCKSAuth IsolateClientProtocol IsolateDestPort IsolateDestAddr

# ===== Control port (para Nyx + watchdogs) =====
# [FIX-AUDIT-TOR] Default to local cookie auth so the shipped config verifies
# before any manual secret bootstrap.
ControlPort 127.0.0.1:9051
CookieAuthentication 1
# Para usar senha depois:
#   1. Gere o hash com `tor --hash-password 'sua-senha'`
#   2. Adicione `HashedControlPassword <hash>`
#   3. Defina `CookieAuthentication 0`

# ===== Hardening de disco/memoria =====
AvoidDiskWrites 1
DisableAllSwap 1
DataDirectoryGroupReadable 0
HardwareAccel 1

# ===== Sem relay/exit =====
ClientOnly 1
ExitRelay 0
PublishServerDescriptor 0

# ExitPolicy explicita (defesa em profundidade — mesmo nao sendo relay)
ExitPolicy reject *:*
ExitPolicy reject6 *:*

# ===== IPv6 desativado (consistente com sysctl) =====
ClientUseIPv6 0
ClientPreferIPv6ORPort 0

# ===== Performance/log =====
Log notice file /var/log/tor/notices.log
SafeLogging 1
SafeSocks 1
TestSocks 1
LongLivedPorts 21,22,706,1863,5050,5190,5222,5223,6523,6667,6697,8300

# ===== Guard nodes pinning (opcional, melhora consistencia) =====
NumEntryGuards 3
GuardLifetime 90 days

# ===== Limitar uso de banda (sanidade — nao consumir banda do tunel) =====
BandwidthRate 5 MB
BandwidthBurst 10 MB
