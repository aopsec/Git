# /etc/caddy/Caddyfile
# OpenBox v0.1 — reverse proxy com TLS interno para paineis administrativos.
# Acesso apenas via LAN (firewall bloqueia WAN nas portas 80/443).

{
  # TLS interno (auto self-signed CA local)
  local_certs
  admin off
}

openbox.lan {
  tls internal

  log {
    # [FIX-AUDIT-F2B] Emit a durable access log so Fail2ban can see auth failures.
    output file /var/log/caddy/openbox-access.log
    format json
  }

  # ===== Forward auth via tinyauth/authelia (TODO: deploy externo) =====
  # forward_auth localhost:9091 {
  #   uri /api/verify?rd=https://openbox.lan
  #   copy_headers Remote-User Remote-Groups Remote-Email
  # }

  # Por enquanto: basicauth com bcrypt (gerar com `caddy hash-password`)
  # NOTA: Netdata + bcrypt tem CPU spike conhecido — preferir forward_auth quando disponivel
  basicauth {
    admin REPLACE_WITH_BCRYPT_HASH
  }

  # ===== Netdata =====
  handle_path /netdata/* {
    reverse_proxy 127.0.0.1:19999
  }

  # ===== Uptime Kuma =====
  handle_path /uptime/* {
    reverse_proxy 127.0.0.1:3001
  }

  # ===== Monit =====
  handle_path /monit/* {
    reverse_proxy 127.0.0.1:2812
  }

  # ===== Pi-hole admin =====
  # [FIX-AUDIT-PROXY] Pi-hole must stay on a dedicated loopback admin port so
  # Caddy can own :80/:443 without colliding or proxying back into itself.
  handle_path /pihole/* {
    reverse_proxy 127.0.0.1:8081
  }

  # ===== ntfy =====
  handle_path /ntfy/* {
    reverse_proxy 127.0.0.1:2586
  }

  # ===== Cockpit =====
  handle_path /cockpit/* {
    reverse_proxy 127.0.0.1:9090 {
      header_up Host {http.reverse_proxy.upstream.hostport}
      header_up X-Forwarded-Proto https
    }
  }

  # ===== Jellyfin web (substituiu Stremio no retarget RK3229 v0.2.0) =====
  handle_path /jellyfin/* {
    reverse_proxy 127.0.0.1:8096
  }

  # Fallback
  respond "OpenBox v0.2.0 — use /netdata, /uptime, /monit, /pihole, /ntfy, /cockpit, /jellyfin"
}
