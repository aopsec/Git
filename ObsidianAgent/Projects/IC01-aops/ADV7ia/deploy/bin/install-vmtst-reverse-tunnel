#!/usr/bin/env bash
# [FIX-ADV7IA-VM-03] Install the persistent vmtst reverse tunnel service inside the GNOME Boxes guest.
set -euo pipefail
shopt -s inherit_errexit

DRY_RUN=0

cleanup() {
  :
}

usage() {
  cat <<'EOF'
Usage: install-vmtst-reverse-tunnel [--dry-run]

Copy the dedicated reverse-tunnel key into the vmtst guest, install the
adv7ia-vmtst-reverse-tunnel.service unit, and enable it in guest system scope.
EOF
}

log_info() {
  printf '[INFO] %s\n' "$1"
}

run_cmd() {
  if [[ "${DRY_RUN}" == "1" ]]; then
    printf '+'
    printf ' %q' "$@"
    printf '\n'
    return 0
  fi
  "$@"
}

script_dir() {
  local dir=""
  dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  printf '%s\n' "${dir}"
}

project_root() {
  local dir="$1"
  printf '%s\n' "$(cd "${dir}/../.." && pwd)"
}

ssh_base() {
  local key_path="$1"
  local guest_port="$2"
  printf 'ssh -i %q -o BatchMode=yes -o StrictHostKeyChecking=accept-new -o ConnectTimeout=8 -p %q vmtst@127.0.0.1' "${key_path}" "${guest_port}"
}

main() {
  local script_root=""
  local root=""
  local guest_key="${ADV7IA_VMTST_GUEST_KEY:-${HOME}/.ssh/vmtst_ed25519}"
  local guest_port="${ADV7IA_VMTST_GUEST_PORT:-2222}"
  local tunnel_key="${ADV7IA_VMTST_TUNNEL_KEY:-${HOME}/.ssh/vmtst_tunnel_ed25519}"
  local guest_unit_path="/etc/systemd/system/adv7ia-vmtst-reverse-tunnel.service"
  local unit_source=""
  local ssh_cmd=""

  while (($# > 0)); do
    case "$1" in
      --dry-run)
        DRY_RUN=1
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        printf '[ERROR] unknown argument: %s\n' "$1" >&2
        usage >&2
        return 1
        ;;
    esac
    shift
  done

  if [[ ! -f "${guest_key}" ]]; then
    printf '[ERROR] guest access key missing: %s\n' "${guest_key}" >&2
    return 1
  fi
  if [[ ! -f "${tunnel_key}" ]]; then
    printf '[ERROR] tunnel key missing: %s\n' "${tunnel_key}" >&2
    return 1
  fi

  script_root="$(script_dir)"
  root="$(project_root "${script_root}")"
  unit_source="${root}/deploy/systemd-guest/adv7ia-vmtst-reverse-tunnel.service"

  if [[ ! -f "${unit_source}" ]]; then
    printf '[ERROR] guest unit missing: %s\n' "${unit_source}" >&2
    return 1
  fi

  ssh_cmd="$(ssh_base "${guest_key}" "${guest_port}")"

  log_info "Preparing guest SSH directory"
  run_cmd bash -lc "${ssh_cmd} 'PATH=/usr/local/bin:/usr/bin:/bin; mkdir -p ~/.ssh && chmod 700 ~/.ssh'"

  log_info "Copying dedicated reverse-tunnel key"
  run_cmd bash -lc "${ssh_cmd} 'cat > ~/.ssh/vmtst_tunnel_ed25519 && chmod 600 ~/.ssh/vmtst_tunnel_ed25519' < '${tunnel_key}'"

  log_info "Installing guest reverse-tunnel service"
  run_cmd bash -lc "${ssh_cmd} 'sudo -n install -D -m 0644 /dev/stdin ${guest_unit_path}' < '${unit_source}'"

  log_info "Enabling guest reverse-tunnel service"
  run_cmd bash -lc "${ssh_cmd} 'PATH=/usr/local/bin:/usr/bin:/bin; sudo -n systemctl daemon-reload && sudo -n systemctl enable --now adv7ia-vmtst-reverse-tunnel.service && sudo -n systemctl status adv7ia-vmtst-reverse-tunnel.service --no-pager -l | sed -n \"1,20p\"'"
}

trap cleanup EXIT INT
main "$@"
