# OpenHands deployment environment variables
# Copy to .env and source before running docker compose up

# UID to use inside the sandbox (default: 1000)
ADV7IA_OPENHANDS_SANDBOX_USER_ID=1000

# Host path for the ADV7ia workspace (default: $HOME/ObsidianAgent/Projects/ADV7ia)
ADV7IA_WORKSPACE_DIR=/home/aops/ObsidianAgent/Projects/ADV7ia

# Path to the OpenHands config file (default: $HOME/.openhands/config.toml)
ADV7IA_OPENHANDS_CONFIG=/home/aops/.openhands/config.toml

# Resource limits (optional)
# ADV7IA_OPENHANDS_CPU_LIMIT=4
# ADV7IA_OPENHANDS_MEM_LIMIT=4G
